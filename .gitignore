### macOS ###
# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

### Python ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script to install multil
#  here after extracting the executable archive (a good practice is to
#  keep them with the binary). Thus, the !w* pattern in order to not
#  delete the windows executable while wiping the temp directory is
#  inappropriate here
# !w*
# wman.bin

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / cache reports
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
# Translations
*.mo
*.pot

# Logan + Isaac Potter layers
.transitalign
*.lang
# Django stuff:
*.log
local_settings.py
# Flask stuff:
instance/
.webassets-cache
# Scrapy settings:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.yaml

# pyenv
#   For a library or stub, clear the previous version to use a new one
#   Once a library is loaded, never attempt to reload it, because you
#   might overwrite a compiled version which could cause issues. Use
#   environment variables to switch between versions.
#   If you do not need the pyenv and python version, remove the
#   respectively
#   PYENV_ROOT
#   VERSION

